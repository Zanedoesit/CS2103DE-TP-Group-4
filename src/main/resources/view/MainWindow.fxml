<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml" fx:controller="ui.MainWindow" styleClass="app-root">
    <top>
        <VBox spacing="10" styleClass="hero" BorderPane.alignment="CENTER">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label text="Voyage Planner" styleClass="hero-title" />
                    <Label text="Plan trips, track activities, and keep expenses grounded." styleClass="hero-subtitle" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="hero-action-cluster">
                    <Button text="?" fx:id="helpButton" styleClass="hero-action-button" />
                </HBox>
            </HBox>
            <VBox spacing="4" styleClass="hero-activity-panel">
                <Label text="Live Activity Snapshot" styleClass="hero-panel-title" />
                <HBox spacing="12" styleClass="hero-snapshot-grid">
                    <VBox spacing="6" styleClass="snapshot-column" HBox.hgrow="ALWAYS">
                        <Label text="Ongoing" styleClass="snapshot-column-title" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" prefViewportHeight="168.0" styleClass="snapshot-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="ongoingActivityContainer" spacing="6" />
                            </content>
                        </ScrollPane>
                    </VBox>
                    <VBox spacing="6" styleClass="snapshot-column" HBox.hgrow="ALWAYS">
                        <Label text="Upcoming" styleClass="snapshot-column-title" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" prefViewportHeight="168.0" styleClass="snapshot-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="upcomingActivityContainer" spacing="6" />
                            </content>
                        </ScrollPane>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </top>
    <center>
        <HBox fx:id="homeContent" spacing="16" alignment="TOP_LEFT" BorderPane.alignment="CENTER">
            <VBox spacing="12" alignment="TOP_LEFT" styleClass="card" HBox.hgrow="ALWAYS">
                <Label text="Trips" styleClass="section-title" />
                <ListView fx:id="tripListView" VBox.vgrow="ALWAYS" />
                <HBox spacing="10">
                    <Button text="Add Trip" fx:id="addTripButton" styleClass="add-button" />
                    <Button text="Edit Trip" fx:id="editTripButton" styleClass="edit-button" />
                    <Button text="Delete Trip" fx:id="deleteTripButton" styleClass="delete-button" />
                </HBox>
            </VBox>
        </HBox>
    </center>
    <padding>
        <Insets top="22" right="22" bottom="22" left="22" />
    </padding>
</BorderPane>
