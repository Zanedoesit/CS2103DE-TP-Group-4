<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="ui.TripPage">
    <top>
        <Button text="Back" fx:id="backButton" />
    </top>
    <center>
        <VBox spacing="10" alignment="TOP_LEFT">
            <Label fx:id="tripNameLabel" style="-fx-font-weight: bold; -fx-font-size: 18;" />
            <Label fx:id="tripDateLabel" />
            <Label fx:id="tripLocationLabel" />
            <Label text="Itinerary Timeline" style="-fx-font-weight: bold; -fx-font-size: 14;" />
            <ScrollPane fitToWidth="true" prefHeight="260">
                <content>
                    <VBox fx:id="timelineContainer" spacing="10" />
                </content>
            </ScrollPane>
            <Label text="Activities" style="-fx-font-weight: bold; -fx-font-size: 14;" />
            <ListView fx:id="activityListView" prefHeight="200" />
            <Button text="Add Activity" fx:id="addActivityButton" />
            <Label text="Expenses" style="-fx-font-weight: bold; -fx-font-size: 14;" />
            <ListView fx:id="expenseListView" prefHeight="200" />
            <Button text="Add Expense" fx:id="addExpenseButton" />
        </VBox>
    </center>
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>
</BorderPane>
